            <div class="footer-brand">
                <a href="https://kohza.org/" class="footer-logo">
                    <span class="lb">[</span>KOHZA<span class="lb">]</span>
                </a>
                <p class="footer-tagline">
                    Digital enforcement intelligence.<br />
                    We take down piracy, impersonation, and leaks — at host level.
                </p>
            </div>

            <div class="footer-links">
                <div class="footer-col">
                    <span class="footer-col-label">Site</span>
                    <a href="https://kohza.org/">Home</a>
                    <a href="https://kohza.org/promise">Our Promise</a>
                    <a href="https://kohza.org/#protocol">Protocol</a>
                    <a href="https://kohza.org/#testimonial">Cases</a>
                </div>
                <div class="footer-col">
                    <span class="footer-col-label">Blog</span>
                    <a href="/">All Briefings</a>
                    <a href="https://tally.so/r/rjlpyL" target="_blank" rel="noreferrer">Open a Case</a>
